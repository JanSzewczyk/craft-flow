{
  "allow": [
    "Read",
    "Grep",
    "Glob",
    "Edit",
    "Bash(npm run type-check)",
    "Bash(npm run lint)",
    "Bash(npm run lint:fix)",
    "Bash(npm run prettier:check)",
    "Bash(npm run prettier:write)",
    "Bash(npm run test:*)"
  ],
  "deny": [
    "Read(.env*)",
    "Edit(.env*)",
    "Edit(proxy.ts)",
    "Edit(data/env/server.ts)",
    "Edit(data/env/client.ts)",
    "Edit(drizzle.config.ts)",
    "Edit(drizzle/**)",
    "Bash(git push --force*)",
    "Bash(git reset --hard*)",
    "Bash(rm -rf*)",
    "Bash(npm run db:push)",
    "Bash(npm run db:migrate)"
  ]
}
